digraph Hill_Climbing_Workflow {
	rankdir=TB
	splines=ortho
	nodesep=0.6
	ranksep=0.8
	size="8,10"
	node [color=black fillcolor=lightblue fontname=Helvetica fontsize=12 margin="0.2,0.1" shape=rectangle style="rounded,filled"]
	A [label=Start]
	B [label="Generate Random Board"]
	C [label="Calculate Conflicts"]
	D [label="Generate Neighbor States"]
	E [label="Choose Best Neighbor"]
	F [label="Conflict Reduced?"]
	G [label="Move to Better State"]
	H [label="Local Optimum Reached"]
	I [label="Solution Found"]
	J [label=End]
	A -> B
	B -> C
	C -> D
	D -> E
	E -> F
	F -> G [xlabel=" Yes "]
	G -> C
	F -> H [xlabel=" No "]
	H -> I
	I -> J
}
